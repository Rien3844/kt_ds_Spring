<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktdsuniversity.edu.board.dao.BoardDao">
    <select id="selectBoardCount" 
            resultType="_int">
       SELECT COUNT(ID)
         FROM BOARD
     </select>
    
    <select id="selectBoardList" 
            resultType="com.ktdsuniversity.edu.board.vo.BoardVO">
       SELECT ID 
            , SUBJECT 
            , CONTENT 
            , EMAIL 
            , VIEW_CNT 
            , TO_CHAR(CRT_DT, 'YYYY-MM-DD HH24:MI:SS') AS CRT_DT
            , TO_CHAR(MDFY_DT, 'YYYY-MM-DD HH24:MI:SS') AS MDFY_DT
            , FILE_NAME 
            , ORIGIN_FILE_NAME 
         FROM BOARD
        ORDER BY ID DESC
    </select>
    
    <insert id="insertNewBoard" parameterType="com.ktdsuniversity.edu.board.vo.request.WriteVO">
       <!-- 새롭게 만들어지는 게시글의 PK값을 미리 생성해서 WriteVO의 id라는 변수에 할당한다. -->
       <selectKey order ="BEFORE" 
                  resultType="string"
                  keyProperty="id"> <!-- string타입의 id라는 변수에 이 값을 넣어주겠다. -->
                   <!-- INSERT가 동작되기 이전에 수행해라. -->
            SELECT 'BO-' || TO_CHAR(SYSDATE, 'YYYYMMDD-') || LPAD(SEQ_BOARD_PK.NEXTVAL, 6, '0')
              FROM DUAL
       </selectKey>
       
       INSERT INTO BOARD 
           (ID
          , SUBJECT
          , CONTENT
          , EMAIL
          , VIEW_CNT
          , CRT_DT
          , MDFY_DT
          , FILE_NAME
          , ORIGIN_FILE_NAME)
          VALUES
           (#{id}
          , #{subject}
          , #{content}
          , #{email}
          , 0
          , SYSDATE
          , SYSDATE
          , NULL
          , NULL)
    </insert>
    
    <!-- viewDetailPage -->
    
    <update id="updateViewCntIncreaseById"
            parameterType="string">
        UPDATE BOARD
           SET VIEW_CNT = VIEW_CNT + 1
         WHERE ID = #{_parameter}
    </update>
    
    <!-- JOIN을 사용하는 쿼리의 결과를
    HAS A를 사용하는 VO에게 값을 할당하기 위한
    태그(BoardVO)
    type = Has A를 사용하는 객체의 이름(+ 패키지)
    id = 보통 result를 받는 객체의 이름 뒤에 Map만 붙인다. -->
    <resultMap type="com.ktdsuniversity.edu.board.vo.BoardVO" 
               id="BoardVOMap"
               autoMapping="true"> <!-- id를 제외한 나머지를 다 넣어줌. -->
      <!-- 쿼리에 사용되는 테이블의 PK값을 변수에 저장할 때 사용. 
      column = 테이블의 PK값 | property = ID값이 할당될 변수-->
      <id column="ID" property="id"/>
      <!-- 쿼리에 사용되는 테이블의 일반 컬럼의 값을 변수에 저장할 때 사용. -->
      <!-- 
      <result column="SUBJECT" property="subject"/>
      <result column="CONTENT" property="content"/>
      <result column="EMAIL" property="email"/>
      <result column="VIEW_CNT" property="viewCnt"/>
      <result column="CRT_DT" property="crtDt"/>
      <result column="MDFY_DT" property="mdfyDt"/>
      <result column="FILE_NAME" property="fileName"/>
      <result column="ORIGIN_FILE_NAME" property="originFileName"/>
       BoardVO에 있는 변수에 한에서만 넣어준다.-->
       
      <!-- BoardVO에 있는 List는 <collection> 태그를 이용한다.
      property = list의 변수 명 | javaType = 해당 변수의 타입
      파일의 확장자 명 까지 써주는게 맞지만, collection은 list를 대응한다 ==> java.util.List대신 list 작성 가능. -->
      <collection property="files"
                  javaType="list"
                  ofType="com.ktdsuniversity.edu.files.vo.FilesVO"
                  autoMapping="true"> 
              <id column="FILE_NUM" property="fileNum"/>
              <id column="FILE_GROUP_ID" property="fileGroupId"/>
              <!--
              <result column="OBFUSCATE_NAME" property="obfuscateName"/>
              <result column="DISPLAY_NAME" property="displayName"/>
              <result column="EXTEND_NAME" property="extendName"/>
              <result column="FILE_LENGTH" property="fileLength"/>
              <result column="FILE_PATH" property="filePath"/>
              -->
      </collection>
    </resultMap>
    <!-- resultType="com.ktdsuniversity.edu.board.vo.BoardVO" ==> JOIN이 없을 때 사용.-->
    <!-- resultMap="resultMap의 id값" ==> JOIN이 있을 때 "반드시" 사용. -->
    <select id="selectBoardById"
            resultMap="BoardVOMap" 
            parameterType="string">
       SELECT B.ID
            , B.SUBJECT
            , B.CONTENT
            , B.EMAIL
            , B.VIEW_CNT
            , TO_CHAR(B.CRT_DT, 'YYYY-MM-DD HH24:MI:SS') AS CRT_DT
            , TO_CHAR(B.MDFY_DT, 'YYYY-MM-DD HH24:MI:SS') AS MDFY_DT
            , B.FILE_NAME
            , B.ORIGIN_FILE_NAME
            , F.FILE_NUM
            , F.FILE_GROUP_ID
            , F.OBFUSCATE_NAME
            , F.DISPLAY_NAME
            , F.EXTEND_NAME
            , F.FILE_LENGTH
            , F.FILE_PATH
         FROM BOARD B
         LEFT OUTER JOIN FILES F
           ON B.ID = F.FILE_GROUP_ID 
        WHERE B.ID = #{_parameter}
    </select>
    
    <delete id="deleteBoardById"
            parameterType="string">
       DELETE
         FROM BOARD 
        WHERE ID = #{_parameter}
    </delete>
    <update id="updateBoardById"
            parameterType="com.ktdsuniversity.edu.board.vo.request.UpdateVO">
        UPDATE BOARD
           SET SUBJECT = #{subject}
             , EMAIL = #{email}
             , CONTENT = #{content}
             , MDFY_DT = SYSDATE
         WHERE ID = #{id}
    </update>
    
</mapper>